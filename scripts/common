#!/bin/bash
set -e

# Install protoc-go (Go port of protoc) to a target directory.
# The binary is named 'protoc' for compatibility.
#
# Usage: install_protoc [target_dir]
#   target_dir: Directory to install to (defaults to $PWD/server/build)
install_protoc() {
    local BUILD_DIR="${1:-$PWD/server/build}"

    mkdir -p "$BUILD_DIR"

    if [ ! -x "$BUILD_DIR/protoc" ]; then
        echo "Installing protoc-go..."
        go install github.com/wham/protoc-go/cmd/protoc-go@latest
        mv "$BUILD_DIR/protoc-go" "$BUILD_DIR/protoc"
    else
        echo "protoc already installed in $BUILD_DIR"
    fi
}

