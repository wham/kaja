#!/bin/bash
set -e

# Install protoc-go (Go port of protoc) to a target directory.
# The binary is named 'protoc' for compatibility. The version is pinned to the
# one required by server/go.mod so the dev CLI tracks the embedded library
# whenever protoc-go is bumped.
#
# Usage: install_protoc [target_dir]
#   target_dir: Directory to install to (defaults to $PWD/server/build)
install_protoc() {
    local BUILD_DIR="${1:-$PWD/server/build}"

    mkdir -p "$BUILD_DIR"

    local VERSION
    VERSION=$(cd "$PWD/server" && go list -m -f '{{.Version}}' github.com/wham/protoc-go)

    echo "Installing protoc-go $VERSION..."
    go install "github.com/wham/protoc-go/cmd/protoc-go@$VERSION"
    mv "$BUILD_DIR/protoc-go" "$BUILD_DIR/protoc"
}

